# Development mode — set to "true" to enable dev mode (uses dev API endpoint and debug logging)
DEV=false

# Password for accessing debug endpoints (enter "test-dev-debug" in station search to trigger login)
DEBUG_PASSWORD=change-me-to-a-strong-password

# Secret key used by Flask for session signing (auto-generated if not set)
FLASK_SECRET_KEY=replace-with-a-random-secret-key

# Optional API key for Transit Tracker API authentication (when enabled on API server)
API_KEY=
