# Development mode — set to "true" to enable dev mode (uses dev API endpoint and debug logging)
DEV=false

# API key required for every endpoint (sent via X-API-Key header)
API_KEY=change-me-to-a-strong-api-key

# Password for accessing debug endpoints (enter "test-dev-debug" in station search to trigger login)
DEBUG_PASSWORD=change-me-to-a-strong-password

# Secret key used by Flask for session signing (auto-generated if not set)
FLASK_SECRET_KEY=replace-with-a-random-secret-key

# PostgreSQL database connection settings
# These are used for coordinate-based map stop lookups.
# You can also provide these via /config/db_connection.txt (see db_connection.txt.example).
# Environment variables take precedence over the connection file.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=username
DB_PASSWORD=password
DB_SSLMODE=prefer
